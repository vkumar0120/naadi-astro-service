---

<section class="py-20 bg-gradient-to-br from-gray-50 via-purple-50 to-indigo-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14">
      <h2 class="text-5xl font-bold mb-6 bg-gradient-to-r from-primary to-spiritual bg-clip-text text-transparent">What Our Clients Say</h2>
      <p class="text-2xl text-gray-700">Thousands of lives transformed through authentic Nadi readings</p>
    </div>
    
    {/* Text Testimonials Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-7xl mx-auto mb-16">
      {testimonials.map(testimonial => (
        <div class="bg-white p-8 rounded-2xl shadow-xl shadow-spiritual hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border-t-4 border-primary group">
          <div class="flex items-center mb-6">
            <div class="w-16 h-16 bg-gradient-to-br from-primary to-spiritual rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg">
              {testimonial.name.charAt(0)}
            </div>
            <div class="ml-5">
              <h4 class="text-xl font-bold text-gray-800">{testimonial.name}</h4>
              <div class="flex text-gold text-xl mt-1">
                {'★★★★★'}
              </div>
            </div>
          </div>
          <p class="text-gray-600 italic leading-relaxed text-lg">"{testimonial.text}"</p>
        </div>
      ))}
    </div>

    {/* Video Testimonials Section - Placeholder for future videos */}
    <div class="bg-white rounded-3xl shadow-2xl shadow-spiritual p-10 max-w-5xl mx-auto border border-primary/20">
      <h3 class="text-3xl font-bold text-center mb-8 text-primary">Video Testimonials</h3>
      <div class="bg-gradient-to-r from-primary/10 to-spiritual/10 rounded-2xl p-12 text-center">
        <div class="text-6xl mb-6">🎥</div>
        <p class="text-gray-800 mb-3 font-bold text-xl">Coming Soon: Watch Real Client Experiences</p>
        <p class="text-gray-600 text-lg">We're collecting video testimonials from our satisfied clients. Check back soon!</p>
        {/* When you have videos, replace above with YouTube embed code */}
        {/* Example:
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {videoTestimonials.map(video => (
            <div class="aspect-video">
              <iframe 
                width="100%" 
                height="100%" 
                src={`https://www.youtube.com/embed/${video.youtubeId}`}
                title={video.title}
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                class="rounded-lg"
              ></iframe>
            </div>
          ))}
        </div>
        */}
      </div>
    </div>

    {/* Trust Message */}
    <div class="text-center mt-14">
      <p class="text-gray-700 text-2xl mb-6">Join thousands of satisfied clients who found clarity through authentic Nadi readings</p>
      <a href="/contact" class="inline-block bg-gradient-to-r from-primary to-spiritual text-white px-12 py-5 rounded-full font-bold text-xl hover:shadow-spiritual transform hover:scale-105 transition-all duration-300 shadow-xl">
        Book Your Reading Today
      </a>
    </div>
  </div>
</section>
