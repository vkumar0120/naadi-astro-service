---
const services = [
  { name: 'Agasthiya Nadi', image: '/assets/images/nadi/1.png', link: '/agasthiya-nadi-astrology' },
  { name: 'Siva Nadi', image: '/assets/images/nadi/2.jpg', link: '/siva-nadi-astrology' },
  { name: 'Bhrigu Nadi', image: '/assets/images/nadi/3.jpg', link: '/bhrigu-nadi-astrology' },
  { name: 'Kaushika Nadi', image: '/assets/images/nadi/4.jpg', link: '/kaushika-nadi-astrology' },
  { name: 'Vashista Nadi', image: '/assets/images/nadi/5.jpg', link: '/vashista-nadi-astrology' },
  { name: 'Bogar Nadi', image: '/assets/images/nadi/6.jpg', link: '/bogar-nadi-astrology' }
];
---

<section class="py-20 bg-white relative overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-spiritual/5 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <h2 class="text-5xl font-bold text-center mb-6 bg-gradient-to-r from-primary to-spiritual bg-clip-text text-transparent">About Nadi Astrology Center Services In Trichy</h2>
    <p class="text-center text-gray-600 text-xl mb-16 max-w-3xl mx-auto">Experience authentic traditional Nadi readings from expert astrologers</p>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      {services.map(service => (
        <a href={service.link} class="text-center group block">
          <div class="mb-4 overflow-hidden rounded-2xl shadow-xl shadow-spiritual aspect-square border-2 border-primary/20 hover:border-primary transition-all duration-300">
            <img 
              src={service.image} 
              alt={service.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
          </div>
          <h3 class="font-bold text-primary text-base group-hover:text-spiritual transition-colors">{service.name}</h3>
        </a>
      ))}
    </div>
  </div>
</section>
