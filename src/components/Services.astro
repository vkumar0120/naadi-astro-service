---
const services = [
  { name: 'Agasthiya Nadi', image: '/assets/images/nadi/1.png', link: '/agasthiya-nadi-astrology' },
  { name: 'Siva Nadi', image: '/assets/images/nadi/2.jpg', link: '/siva-nadi-astrology' },
  { name: 'Bhrigu Nadi', image: '/assets/images/nadi/3.jpg', link: '/bhrigu-nadi-astrology' },
  { name: 'Kaushika Nadi', image: '/assets/images/nadi/4.jpg', link: '/kaushika-nadi-astrology' },
  { name: 'Vashista Nadi', image: '/assets/images/nadi/5.jpg', link: '/vashista-nadi-astrology' },
  { name: 'Bogar Nadi', image: '/assets/images/nadi/6.jpg', link: '/bogar-nadi-astrology' }
];
---

<section class="py-12 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-8 text-gray-800">About Nadi Astrology Center Services In Trichy</h2>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
      {services.map(service => (
        <a href={service.link} class="text-center group block">
          <div class="mb-2 overflow-hidden rounded-lg shadow-md aspect-square">
            <img 
              src={service.image} 
              alt={service.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
            />
          </div>
          <h3 class="font-semibold text-gray-800 text-sm group-hover:text-primary transition-colors">{service.name}</h3>
        </a>
      ))}
    </div>
  </div>
</section>
