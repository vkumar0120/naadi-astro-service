---
// Callback Form Component
---

<section class="py-20 bg-gradient-to-br from-primary via-spiritual to-secondary text-white relative overflow-hidden">
  <!-- Decorative Background -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-20 w-96 h-96 bg-gold rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-20 w-96 h-96 bg-purple-light rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">Get a Call Back from <span class="text-gold-light">Nadi Experts</span></h2>
        <p class="text-2xl opacity-95">Fill out the form to receive a call back from our team within 2-4 hours</p>
      </div>

      <div class="bg-white/15 backdrop-blur-xl rounded-3xl p-10 md:p-12 shadow-2xl border border-white/20">
        <form action="/api/callback" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="firstName" class="block text-base font-bold mb-3">First Name *</label>
            <input 
              type="text" 
              id="firstName" 
              name="firstName" 
              required
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all shadow-lg text-lg"
              placeholder="Enter your first name"
            />
          </div>

          <div>
            <label for="lastName" class="block text-base font-bold mb-3">Last Name</label>
            <input 
              type="text" 
              id="lastName" 
              name="lastName"
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all shadow-lg text-lg"
              placeholder="Enter your last name"
            />
          </div>

          <div>
            <label for="phone" class="block text-base font-bold mb-3">Phone Number *</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              required
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all shadow-lg text-lg"
              placeholder="+91 XXXXX XXXXX"
            />
          </div>

          <div>
            <label for="email" class="block text-base font-bold mb-3">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all shadow-lg text-lg"
              placeholder="your@email.com"
            />
          </div>

          <div class="md:col-span-2">
            <label for="timePreference" class="block text-base font-bold mb-3">Preferable Time for Call Back</label>
            <select 
              id="timePreference" 
              name="timePreference"
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all shadow-lg text-lg"
            >
              <option value="">Select a time slot</option>
              <option value="morning">Morning (9 AM - 12 PM)</option>
              <option value="afternoon">Afternoon (12 PM - 4 PM)</option>
              <option value="evening">Evening (4 PM - 8 PM)</option>
              <option value="anytime">Anytime</option>
            </select>
          </div>

          <div class="md:col-span-2">
            <label for="message" class="block text-base font-bold mb-3">Message (Optional)</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4"
              class="w-full px-5 py-4 rounded-xl bg-white/95 text-gray-800 border-2 border-transparent focus:border-gold focus:outline-none transition-all resize-none shadow-lg text-lg"
              placeholder="Tell us briefly about your query..."
            ></textarea>
          </div>

          <div class="md:col-span-2 text-center">
            <button 
              type="submit"
              class="bg-gradient-to-r from-gold to-accent text-secondary px-16 py-5 rounded-full font-bold text-xl hover:shadow-gold transform hover:scale-105 transition-all duration-300 shadow-2xl"
            >
              Request Call Back
            </button>
          </div>
        </form>
      </div>

      <div class="text-center mt-8 text-white/90">
        <p class="text-base">🔒 We respect your privacy. Your information will never be shared with third parties.</p>
      </div>
    </div>
  </div>
</section>
