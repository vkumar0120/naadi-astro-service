---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  url?: string;
}

const { 
  title, 
  description = "Sree Agasthiya Maha Siva Nadi Astrology - Expert Nadi Astrology Services in Vaitheeswaran Koil and Trichy",
  keywords = "nadi astrology, siva nadi, vaitheeswaran koil, nadi jothidam, palm leaf astrology, agasthiya nadi, tamil nadu astrology, trichy astrologer, accurate nadi predictions, online nadi reading",
  image = "https://naadiastroservice.com/assets/images/nadi-astrology-og.jpg",
  url = Astro.url.href
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Guruji Sri Thillaimani - Sree Agasthiya Maha Siva Nadi Astrology" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Sree Agasthiya Maha Siva Nadi Astrology" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Sree Agasthiya Maha Siva Nadi Astrology",
        "image": "https://naadiastroservice.com/assets/images/nadi-astrology-og.jpg",
        "description": "Authentic Nadi Astrology services with ancient palm leaf predictions. Expert readings by Guruji Thillaimani with 25+ years experience.",
        "address": [
          {
            "@type": "PostalAddress",
            "streetAddress": "5/165, Big Street, Near Vaitheeswaran Temple",
            "addressLocality": "Vaitheeswaran Koil",
            "addressRegion": "Tamil Nadu",
            "postalCode": "609117",
            "addressCountry": "IN"
          },
          {
            "@type": "PostalAddress",
            "streetAddress": "B14/27, EVS Street, Renga Nagar, KVB Bank Upstairs",
            "addressLocality": "Srirangam, Trichy",
            "addressRegion": "Tamil Nadu",
            "postalCode": "620006",
            "addressCountry": "IN"
          }
        ],
        "geo": [
          {
            "@type": "GeoCoordinates",
            "latitude": "11.0833",
            "longitude": "79.5167"
          },
          {
            "@type": "GeoCoordinates",
            "latitude": "10.8505",
            "longitude": "78.6956"
          }
        ],
        "url": "https://naadiastroservice.com",
        "telephone": ["+919500639334", "+919842020237"],
        "email": "ma.thillaimani@gmail.com",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
            "opens": "06:00",
            "closes": "21:00"
          }
        ],
        "priceRange": "$$",
        "sameAs": [
          "https://www.facebook.com/agasthiyamahasivanaadi",
          "https://www.instagram.com/agasthiyamahasivanaadi",
          "https://www.youtube.com/@agasthiyamahasivanaadi"
        ],
        "areaServed": [
          {
            "@type": "City",
            "name": "Vaitheeswaran Koil"
          },
          {
            "@type": "City",
            "name": "Trichy"
          },
          {
            "@type": "State",
            "name": "Tamil Nadu"
          },
          {
            "@type": "Country",
            "name": "India"
          }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Nadi Astrology Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Agasthiya Nadi Astrology",
                "description": "Ancient palm leaf predictions from Sage Agastya"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Siva Nadi Astrology",
                "description": "Divine predictions from Lord Shiva for spiritual guidance"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Online Nadi Consultation",
                "description": "Remote palm leaf reading via video call"
              }
            }
          ]
        }
      }
    </script>
    
    <title>{title}</title>
  </head>
  <body class="bg-gray-50">
    <slot />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
