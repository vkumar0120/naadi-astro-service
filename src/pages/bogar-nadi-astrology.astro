---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Bogar Nadi Astrology - Siddha Bogar Predictions"
  description="Bogar Nadi Astrology contains mystical predictions by Siddha Bogar. Get insights on health, alchemy, spiritual powers, and life transformations through authentic Bogar Nadi readings."
  keywords="bogar nadi astrology, siddha bogar, bogar siddha predictions, bogar palm leaf, siddha medicine astrology"
>
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Bogar Nadi Astrology
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Bogar Nadi is a mystical form of Nadi Astrology attributed to Siddha Bogar, one of the 18 great Siddhars known for his expertise in medicine, alchemy, and yoga. These palm leaf manuscripts contain unique insights into health, healing, and spiritual transformation.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What is Bogar Nadi?</h2>
            <p class="mb-4">
              Bogar Nadi refers to the palm leaf manuscripts written by Siddha Bogar, a legendary figure in Tamil Siddha tradition known for his mastery over medicine, metallurgy, and mystical sciences. These texts combine astrological predictions with health guidance and spiritual practices.
            </p>
            <p>
              The readings from Bogar Nadi are particularly valuable for health issues, understanding body-mind connection, learning about natural remedies, and achieving physical and spiritual transformation through Siddha practices.
            </p>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Key Features of Bogar Nadi</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Predictions by the great Siddha Bogar</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Health and healing predictions</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Siddha medicine and natural remedies</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Body-mind-spirit connection insights</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Yogic and tantric practices guidance</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Mystical powers and siddhis information</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Physical and spiritual transformation path</span>
              </li>
            </ul>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "Bogar Nadi readings reveal the secrets of health, longevity, and spiritual transformation."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors mr-4">
            Book Bogar Nadi Reading
          </a>
          <a href="tel:+919500639334" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-semibold hover:bg-primary hover:text-white transition-colors">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
