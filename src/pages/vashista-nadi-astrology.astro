---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Vashista Nadi Astrology - Sage Vashistha Predictions"
  description="Vashista Nadi Astrology contains ancient wisdom by Sage Vashistha. Get insights on dharma, family life, spiritual growth, and destiny through authentic Vashista Nadi readings."
  keywords="vashista nadi astrology, vashistha nadi, sage vashistha predictions, vashistha palm leaf, dharma guidance"
>
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Vashista Nadi Astrology
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Vashista Nadi is a divine form of Nadi Astrology based on the wisdom of Sage Vashistha, one of the most revered sages and the guru of Lord Rama. These palm leaf manuscripts contain profound insights on dharma, righteous living, and spiritual wisdom.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What is Vashista Nadi?</h2>
            <p class="mb-4">
              Vashista Nadi refers to the palm leaf manuscripts written by Sage Vashistha, known for his deep wisdom, patience, and dharmic principles. These sacred texts emphasize righteous living, family values, and the balanced path of spiritual and material success.
            </p>
            <p>
              The readings from Vashista Nadi are particularly valuable for understanding one's dharma (life purpose), resolving family matters, and achieving harmony between spiritual and worldly pursuits.
            </p>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Key Features of Vashista Nadi</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Predictions by the great Sage Vashistha</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Dharma and life purpose guidance</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Family harmony and relationship insights</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Balance between spiritual and material life</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Ancestral blessings and lineage matters</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Wisdom for righteous decision-making</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Peaceful and harmonious living guidance</span>
              </li>
            </ul>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "Vashista Nadi readings guide you toward a life of dharma, wisdom, and harmonious success."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors mr-4">
            Book Vashista Nadi Reading
          </a>
          <a href="tel:+919500639334" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-semibold hover:bg-primary hover:text-white transition-colors">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
