---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Kaushika Nadi Astrology - Sage Vishwamitra Predictions"
  description="Kaushika Nadi Astrology contains predictions by Sage Kaushika (Vishwamitra). Get unique life insights, spiritual guidance, and future predictions through Kaushika Nadi readings."
  keywords="kaushika nadi astrology, vishwamitra nadi, kaushika predictions, rare nadi astrology, sage vishwamitra"
>
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Kaushika Nadi Astrology
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Kaushika Nadi is a rare and powerful form of Nadi Astrology attributed to Sage Kaushika, also known as Vishwamitra. These sacred palm leaves contain profound predictions about transformation, spiritual evolution, and life's challenging situations.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What is Kaushika Nadi?</h2>
            <p class="mb-4">
              Kaushika Nadi refers to the palm leaf manuscripts written by Sage Kaushika (Vishwamitra), a sage known for his intense spiritual practices and transformation from a king to a Brahmarishi. These texts reflect his unique perspective on life's challenges and spiritual growth.
            </p>
            <p>
              The readings from Kaushika Nadi are particularly valuable for those facing major life transformations, seeking spiritual advancement, or dealing with complex karmic situations.
            </p>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Key Features of Kaushika Nadi</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Predictions by Sage Kaushika (Vishwamitra)</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Insights on life transformations and changes</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Spiritual advancement and enlightenment guidance</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Complex karmic situation analysis</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Obstacles and challenge resolution</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Power, authority, and leadership insights</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Unique remedies for difficult situations</span>
              </li>
            </ul>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "Kaushika Nadi readings illuminate the path through life's most challenging transformations."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors mr-4">
            Book Kaushika Nadi Reading
          </a>
          <a href="tel:+919500639334" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-semibold hover:bg-primary hover:text-white transition-colors">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
