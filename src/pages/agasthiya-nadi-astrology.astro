---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Agasthiya Nadi Astrology - Ancient Sage Predictions"
  description="Agasthiya Nadi Astrology contains ancient predictions by Sage Agastya. Get accurate life predictions, past karma insights, and future guidance through authentic Agasthiya Nadi readings."
  keywords="agasthiya nadi astrology, agastya nadi, sage agastya predictions, ancient nadi, palm leaf astrology, agasthya nadi jothidam"
>
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Agasthiya Nadi Astrology
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Agasthiya Nadi is the most revered and ancient form of Nadi Astrology, containing predictions written by the great Sage Agastya thousands of years ago. These sacred palm leaf manuscripts hold the life stories and destinies of individuals with remarkable accuracy.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What is Agasthiya Nadi?</h2>
            <p class="mb-4">
              Agasthiya Nadi refers to the original palm leaf manuscripts penned by Sage Agastya, one of the Saptarishis (seven great sages) of ancient India. These sacred texts contain detailed predictions about individuals who would seek them in the future, written with divine foresight.
            </p>
            <p>
              The readings from Agasthiya Nadi cover all aspects of life including career, marriage, health, wealth, spiritual growth, and provide specific remedies for overcoming challenges and improving life circumstances.
            </p>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Key Features of Agasthiya Nadi</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Ancient predictions by Sage Agastya</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Detailed life predictions from birth to death</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Past karma and its effects on present life</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Career, education, and business guidance</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Marriage compatibility and family matters</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Powerful remedies and spiritual practices</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Wealth, health, and longevity predictions</span>
              </li>
            </ul>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "Agasthiya Nadi readings reveal your life's blueprint with stunning accuracy, offering guidance for a fulfilling life."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors mr-4">
            Book Agasthiya Nadi Reading
          </a>
          <a href="tel:+919500639334" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-semibold hover:bg-primary hover:text-white transition-colors">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
