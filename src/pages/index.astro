---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import WhyUs from '../components/WhyUs.astro';
import ReadingProcess from '../components/ReadingProcess.astro';
import DiscoverSection from '../components/DiscoverSection.astro';
import TrustBadges from '../components/TrustBadges.astro';
import CallbackForm from '../components/CallbackForm.astro';
import WhatsIncluded from '../components/WhatsIncluded.astro';
import FounderSection from '../components/FounderSection.astro';
---

<Layout 
  title="Best Nadi Astrology in Vaitheeswaran Koil | Authentic Palm Leaf Readings by Guruji Thillaimani"
  description="Discover your destiny with authentic Nadi Astrology readings in Vaitheeswaran Koil & Trichy. Ancient palm leaf predictions by expert astrologer Guruji Thillaimani with 25+ years experience. Online & in-person consultations available. Book now!"
  keywords="nadi astrology, vaitheeswaran koil nadi, siva nadi, palm leaf astrology, nadi jothidam, agasthiya nadi, trichy astrologer, tamil nadu nadi reading, authentic nadi astrology, online nadi reading, guruji thillaimani, best nadi astrologer"
>
  <Header />
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-amber-600 to-secondary text-white py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 animate-fade-in-up">
          Your Life Written on Ancient Palm Leaves
        </h1>
        <p class="text-xl md:text-2xl mb-8 animate-fade-in" style="animation-delay: 0.2s;">
          Discover the predictions and guidance recorded centuries ago — uniquely for you
        </p>
        <div class="mb-8 flex justify-center animate-fade-in" style="animation-delay: 0.4s;">
          <img src="/assets/images/nadi/mem2.jpg" alt="Ancient Nadi Palm Leaf Astrology Reading by Guruji Thillaimani at Vaitheeswaran Koil Temple - Authentic Spiritual Guidance" class="rounded-lg shadow-lg max-w-full h-auto md:max-w-2xl" />
        </div>
        <p class="text-lg mb-8 leading-relaxed animate-fade-in" style="animation-delay: 0.6s;">
          Authentic Sree Agasthiya Maha Siva Nadi Astrology from Vaitheeswaran Koil. 
          Expert guidance for your past, present, and future with 25+ years of experience.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in" style="animation-delay: 0.8s;">
          <a href="/contact" class="bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
            Request Call Back
          </a>
          <a href="tel:+919500639334" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white hover:text-primary transition-colors">
            Call: +91 95006 39334
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <TrustBadges />

  <!-- Founder Section -->
  <FounderSection />

  <!-- About Palm Leaves Section -->
  <section class="py-16 bg-gradient-to-br from-amber-50 via-orange-50 to-yellow-50 relative overflow-hidden">
    <!-- Traditional Pattern Background -->
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(139, 69, 19, 0.2) 35px, rgba(139, 69, 19, 0.2) 70px), repeating-linear-gradient(-45deg, transparent, transparent 35px, rgba(184, 134, 11, 0.2) 35px, rgba(184, 134, 11, 0.2) 70px);"></div>
    <div class="absolute top-10 left-10 w-32 h-32 border-4 border-primary/20 rounded-full"></div>
    <div class="absolute bottom-10 right-10 w-40 h-40 border-4 border-secondary/20 rounded-full"></div>
    <div class="absolute top-1/2 right-20 w-24 h-24 border-4 border-primary/10 transform rotate-45"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-8 md:p-12">
        <h2 class="text-4xl font-bold text-center mb-8 text-gray-800 animate-slide-in-left">About Palm Leaves</h2>
        <div class="prose prose-lg max-w-none text-gray-700">
          <p class="text-lg leading-relaxed mb-6 animate-fade-in" style="animation-delay: 0.2s;">
            Palm Leaves are ancient manuscripts written by enlightened sages thousands of years ago, who foresaw the lives of millions of souls. These leaves contain your life blueprint—your destiny, challenges, purpose, relationships, career, karma, remedies, and what lies ahead.
          </p>
          <p class="text-lg leading-relaxed mb-6 animate-fade-in" style="animation-delay: 0.4s;">
            Each leaf is written for a specific individual and is revealed only when the time is right. The Nadi reader uses your thumb impression to locate your unique palm leaf. It is scientifically proven that every individual's whirls, loops, and movements are unique and almost impossible to duplicate.
          </p>
          <p class="text-lg leading-relaxed mb-6 animate-fade-in" style="animation-delay: 0.6s;">
            A Nadi reading helps people understand their true path, make aligned decisions, clear karmic blocks, and move forward with confidence. Get personalized Nadi astrology readings from our authentic center at Vaitheeswaran Koil, available both online and in-person.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Discover What's Meant for You -->
  <DiscoverSection />

  <!-- Reading Process -->
  <ReadingProcess />

  <!-- What's Included -->
  <WhatsIncluded />

  <!-- Services Section -->
  <Services />

  <!-- Vaitheeswaran Koil Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-center mb-8 text-gray-800 animate-slide-in-right">Vaitheeswaran Koil</h2>
        <div class="prose prose-lg max-w-none text-gray-700">
          <p class="text-lg leading-relaxed mb-6 animate-fade-in" style="animation-delay: 0.2s;">
            Vaitheeswaran Koil, a renowned pilgrimage site in Tamil Nadu, India, holds significant importance in Sree Agasthiya Shiva Maha Nadi astrology, a divine form of predictive science. Nestled along the banks of the sacred Vaitheeswaran Temple dedicated to Lord Shiva, this ancient practice is believed to have originated from the sage Agastya, who documented the destinies of individuals on palm leaves thousands of years ago.
          </p>
          <p class="text-lg leading-relaxed mb-6 animate-fade-in" style="animation-delay: 0.4s;">
            Seekers journey to Vaitheeswaran Koil seeking the guidance of these mystical palm leaves, which are said to hold precise insights into one's past, present, and future. The spiritual ambiance of the temple and the resonance of the nearby Pamba River add to the mystique of the experience, drawing pilgrims and astrologers alike in search of clarity, healing, and spiritual growth.
          </p>
        </div>
        
        <div class="bg-primary/10 border-l-4 border-primary p-6 rounded mt-8">
          <h3 class="text-2xl font-bold mb-4 text-gray-800">Our Vaitheeswaran Koil Nadi astrologer can help you in many ways:</h3>
          <ul class="space-y-2 text-gray-700">
            <li>✓ Insights about your past, future, and personality traits</li>
            <li>✓ Health and lifespan improvements</li>
            <li>✓ Career, education, and business guidance</li>
            <li>✓ Financial and family matters</li>
            <li>✓ Marriage and relationship issues</li>
            <li>✓ Problem prevention in your current life</li>
          </ul>
          <div class="mt-6 text-center">
            <a href="/vaitheeswaran-koil" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
              Learn More
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <WhyUs />

  <!-- Testimonials -->
  <Testimonials />

  <!-- Callback Form -->
  <CallbackForm />

  <!-- FAQ Section -->
  <FAQ />

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-br from-primary via-amber-600 to-secondary text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full translate-x-1/2 translate-y-1/2"></div>
    </div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <div class="text-6xl mb-6 animate-bounce-in">🕉️</div>
      <h2 class="text-3xl md:text-5xl font-bold mb-6 animate-bounce-in">Find Your Palm Leaf Today!</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto animate-fade-in leading-relaxed" style="animation-delay: 0.3s;">
        Ancient Indian sages wrote the destinies of future seekers on sacred palm leaves, and one of them may be yours. 
        We help you find your leaf and receive its guidance, giving you clarity and direction for your life's path.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in" style="animation-delay: 0.5s;">
        <a href="/contact" class="bg-white text-primary px-10 py-4 rounded-full font-bold text-lg hover:bg-gray-100 transform hover:scale-105 transition-all duration-300 shadow-xl">
          Request Call Back
        </a>
        <a href="tel:+919500639334" class="border-2 border-white text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-primary transform hover:scale-105 transition-all duration-300">
          Call: +91 95006 39334
        </a>
      </div>
      <p class="mt-6 text-white/90 text-sm">✅ Authentic readings from Vaitheeswaran Koil • 🎥 Video recording included • 💯 25+ years experience</p>
    </div>
  </section>

  <Footer />
  <WhatsAppButton />
</Layout>
