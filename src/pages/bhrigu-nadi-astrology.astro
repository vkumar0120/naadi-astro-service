---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Bhrigu Nadi Astrology - Sage Bhrigu Predictions"
  description="Bhrigu Nadi Astrology contains predictions by Sage Bhrigu. Get detailed life analysis, career guidance, and future predictions through authentic Bhrigu Nadi readings."
  keywords="bhrigu nadi astrology, bhrigu samhita, sage bhrigu predictions, bhrigu nadi jothidam, bhrigu palm leaf"
>
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Bhrigu Nadi Astrology
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Bhrigu Nadi is a highly accurate form of Nadi Astrology based on the divine knowledge of Sage Bhrigu, one of the greatest seers of ancient India. These palm leaf manuscripts contain comprehensive life predictions written with remarkable precision.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What is Bhrigu Nadi?</h2>
            <p class="mb-4">
              Bhrigu Nadi, also known as Bhrigu Samhita, refers to the astrological treatise written by Sage Bhrigu. These ancient manuscripts contain detailed horoscopes and life predictions for millions of individuals, compiled through divine inspiration and astronomical calculations.
            </p>
            <p>
              The readings from Bhrigu Nadi are known for their exceptional accuracy in predicting life events, career paths, financial matters, and providing practical solutions for life's challenges.
            </p>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Key Features of Bhrigu Nadi</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Predictions by the renowned Sage Bhrigu</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Detailed career and professional guidance</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Financial prosperity and wealth predictions</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Marriage timing and compatibility analysis</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Health and longevity insights</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Children and family life predictions</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Effective remedies for life challenges</span>
              </li>
            </ul>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "Bhrigu Nadi readings provide precise insights into your professional and financial future."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors mr-4">
            Book Bhrigu Nadi Reading
          </a>
          <a href="tel:+919500639334" class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-full font-semibold hover:bg-primary hover:text-white transition-colors">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
